# ============================================================================
# linkedin-mcp-pro — Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# LinkedIn Authentication
# ----------------------------------------------------------------------------
# Get these from your browser's DevTools while logged into LinkedIn:
#   1. Open https://www.linkedin.com in Chrome/Firefox
#   2. Press F12 → Application tab → Cookies → https://www.linkedin.com
#   3. Copy the values for `li_at` and `JSESSIONID`
#
# For browser-based writes, you only need LI_AT (Patchright will derive
# the rest from your browser session). For API-based reads, you need both.
#
# Alternative: set LI_AT_FILE to a path containing only the cookie value
# (one line, no quotes). Useful for keeping secrets out of env files.

LI_AT=your-li_at-cookie-here
JSESSIONID=ajax:your-jsessionid-value-here

# OR use file-based (recommended for production):
# LI_AT_FILE=/etc/linkedin-mcp-pro/li_at
# JSESSIONID_FILE=/etc/linkedin-mcp-pro/jsessionid

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_TRANSPORT=stdio          # "stdio" or "streamable-http"
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Safety — daily limits (your daily workflow)
# ----------------------------------------------------------------------------
# All caps are HARD-enforced. Set conservatively; increase gradually.
DAILY_LIMIT_CONNECTION_REQUESTS=20
DAILY_LIMIT_POSTS=2
DAILY_LIMIT_MESSAGES=30
DAILY_LIMIT_COMMENTS=30
DAILY_LIMIT_REACTIONS=100

# ----------------------------------------------------------------------------
# Safety — timing
# ----------------------------------------------------------------------------
# Business hours: actions only run during these hours (24h format, your TZ)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=20
BUSINESS_DAYS=mon,tue,wed,thu,fri   # comma-separated: mon,tue,wed,thu,fri,sat,sun

# Min/max delay between actions (seconds). Random in this range.
ACTION_JITTER_MIN_SECONDS=180      # 3 min
ACTION_JITTER_MAX_SECONDS=900      # 15 min

# ----------------------------------------------------------------------------
# Safety — warm-up mode
# ----------------------------------------------------------------------------
# If you have a fresh/risky account, enable warm-up. First 4 weeks ramp up.
WARMUP_ENABLED=true
WARMUP_WEEK_1_LIMIT=5
WARMUP_WEEK_2_LIMIT=10
WARMUP_WEEK_3_LIMIT=15
# Week 4+ uses DAILY_LIMIT_* values

# ----------------------------------------------------------------------------
# Safety — 429 / rate-limit handling
# ----------------------------------------------------------------------------
RATE_LIMIT_BACKOFF_BASE=2          # multiplier for 429 retry delay
RATE_LIMIT_MAX_RETRIES=3
RATE_LIMIT_AUTO_PAUSE=true         # auto-pause all writes on 429

# ----------------------------------------------------------------------------
# Browser Profile (v0.4+ — recommended over raw cookie paste)
# ----------------------------------------------------------------------------
# Path where the persistent Chrome profile is stored. The profile is created
# by `linkedin-mcp login` (interactive) or scripts/cookie_to_profile.py (from
# a single li_at cookie). After setup, all MCP calls reuse the profile.
# Default: ~/.linkedin-mcp/profile/
LINKEDIN_MCP_PROFILE_DIR=~/.linkedin-mcp/profile

# Proxy for LinkedIn browser traffic. Required if your server is on a
# datacenter IP (AWS, GCP, etc.) and LinkedIn blocks you. See docs/PROXY_SETUP.md
# for 5 setup options (laptop SOCKS, cloudflared, Termux, residential, WireGuard).
# Examples:
#   LINKEDIN_MCP_PROXY=socks5://127.0.0.1:1080
#   LINKEDIN_MCP_PROXY=socks5://user:pass@proxy.example.com:22225
#   LINKEDIN_MCP_PROXY=http://user:pass@proxy.example.com:8080
# LINKEDIN_MCP_PROXY=socks5://127.0.0.1:1080

# ----------------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------------
DB_PATH=./data/linkedin-mcp-pro.db
BROWSER_PROFILE_DIR=./data/browser-profile
AUDIT_LOG_RETENTION_DAYS=90

# ----------------------------------------------------------------------------
# Notifications — Telegram alerts for the dead-man switch (v0.5.0)
# ----------------------------------------------------------------------------
# The dead-man switch sends a Telegram message if you stop posting for
# more than LINKEDIN_MCP_DEADMAN_THRESHOLD_DAYS days (default 3).
# Create a bot via @BotFather, get the chat id via @userinfobot or
# @RawDataBot, and put both values here.
#
# If these are unset, the dead-man switch still works — it just logs
# warnings + audit rows instead of sending a message. It will never
# crash the daily systemd timer because of missing config.
#
# Get a bot token:  https://t.me/BotFather  →  /newbot
# Get a chat id:    message your bot, then curl
#                   https://api.telegram.org/bot<TOKEN>/getUpdates
#                   and look for chat.id.
# LINKEDIN_MCP_TELEGRAM_BOT_TOKEN=123456789:AA...
# LINKEDIN_MCP_TELEGRAM_CHAT_ID=987654321

# How many days of silence before the dead-man switch alerts (default 3).
# Can also be changed at runtime via: linkedin-mcp deadman set-threshold N
# LINKEDIN_MCP_DEADMAN_THRESHOLD_DAYS=3
